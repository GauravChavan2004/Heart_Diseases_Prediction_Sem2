@model HeartDiseasePrediction.Models.User

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow p-4">

                <h2 class="text-center text-danger mb-4">
                    User Registration
                </h2>

                <form method="post">

                    <div class="mb-3">
                        <label>Name</label>
                        <input asp-for="Name"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="Email"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Age</label>
                        <input asp-for="Age"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Mobile Number</label>
                        <input asp-for="MobileNo"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Password</label>
                        <input asp-for="Password"
                               type="password"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Confirm Password</label>
                        <input type="password"
                               name="ConfirmPassword"
                               class="form-control" />
                    </div>

                    <button type="submit"
                            class="btn btn-danger w-100">

                        Register

                    </button>

                </form>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-danger mt-3">
                        @ViewBag.Message
                    </div>
                }

            </div>

        </div>

    </div>

</div>