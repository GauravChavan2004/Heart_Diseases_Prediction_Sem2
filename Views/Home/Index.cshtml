<div class="hero-section text-center">

    <div class="container">

        <h1 class="hero-title">
            Heart Disease Prediction System
        </h1>

        <p class="lead mt-4">
            AI-powered healthcare prediction using Machine Learning
        </p>

        <a asp-controller="Prediction"
           asp-action="Predict"
           class="btn btn-light btn-lg mt-4 px-5">

            Predict Now

        </a>

    </div>

</div>

<div class="container mt-5">

    <div class="row text-center">

        <div class="col-md-4">

            <div class="card shadow p-4">

                <i class="fas fa-heartbeat fa-3x text-danger mb-3"></i>

                <h4>AI Prediction</h4>

                <p>
                    Predict heart disease risk using machine learning.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow p-4">

                <i class="fas fa-chart-line fa-3x text-primary mb-3"></i>

                <h4>Analytics Dashboard</h4>

                <p>
                    Analyze patient prediction statistics visually.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow p-4">

                <i class="fas fa-user-md fa-3x text-success mb-3"></i>

                <h4>Healthcare Support</h4>

                <p>
                    Improve healthcare decisions using AI insights.
                </p>

            </div>

        </div>

    </div>

</div>