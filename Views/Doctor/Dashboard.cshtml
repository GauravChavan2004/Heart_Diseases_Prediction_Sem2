@model IEnumerable<HeartDiseasePrediction.Models.Prediction>

<div class="container mt-5">

    <div class="card shadow p-4">

        <h2 class="text-center text-primary mb-4">
            Doctor Dashboard
        </h2>

        <p class="text-center">
            Welcome Dr.
            <strong>
                @Context.Session.GetString("DoctorName")
            </strong>
        </p>

        <hr />
        <div class="table-responsive">
            <table class="table table-bordered table-striped">

                <thead class="table-dark">

                    <tr>
                        <th>Patient Name</th>
                        <th>Age</th>
                        <th>Gender</th>
                        <th>Blood Pressure</th>
                        <th>Cholesterol</th>
                        <th>Heart Rate</th>
                        <th>Result</th>
                        <th>Recommendation</th>
                        <th>Medicine</th>
                        <th>Tests</th>
                        <th>Action</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Recommended By</th>
                        <th>Recommendation Date</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.PatientName</td>

                            <td>@item.Age</td>

                            <td>@item.Sex</td>

                            <td>@item.RestingBP</td>

                            <td>@item.Cholesterol</td>

                            <td>@item.MaxHR</td>

                            <td>@item.Result</td>
                            <td>
                                @item.DoctorRecommendation
                            </td>

                            <td>
                                @item.SuggestedMedicine
                            </td>

                            <td>
                                @item.SuggestedTests
                            </td>

                            <td>

                                <a asp-controller="Doctor"
                                   asp-action="AddRecommendation"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm">

                                    Add Recommendation

                                </a>

                            </td>
                            <td>

                                @if (item.Result.Contains("High"))
                                {
                                    <span class="badge bg-danger">
                                        High Risk
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Low Risk
                                    </span>
                                }

                            </td>

                            <td>
                                @item.PredictionDate
                            </td>
                            <td>@item.RecommendedBy</td>

                            <td>@item.RecommendationDate</td>
                        </tr>
                    }

                </tbody>

            </table>
        </div>

    </div>

</div>