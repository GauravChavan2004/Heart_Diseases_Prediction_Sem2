<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Heart Disease Prediction</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>

        body {
            background-color: #f5f7fa;
            font-family: 'Segoe UI';
        }

        .navbar {
            background: linear-gradient(to right, #e63946, #c1121f);
        }

        .navbar-brand,
        .nav-link {
            color: white !important;
            font-weight: 500;
        }

        .hero-section {
            background: linear-gradient(to right, #e63946, #ff6b6b);
            color: white;
            padding: 100px 0;
            border-radius: 0 0 30px 30px;
        }

        .hero-title {
            font-size: 50px;
            font-weight: bold;
        }

        .card {
            border: none;
            border-radius: 15px;
        }

        .footer {
            background: #212529;
            color: white;
            padding: 20px;
            margin-top: 50px;
        }

        .btn-danger {
            background: #e63946;
            border: none;
        }

        .btn-danger:hover {
            background: #c1121f;
        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark shadow">

        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">

                <i class="fas fa-heartbeat"></i>
                HeartCare AI

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbarNav">

                <ul class="navbar-nav ms-auto">
                    
                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var doctorId = Context.Session.GetInt32("DoctorId");
                        var admin = Context.Session.GetString("Admin");
                    }

                    @if (userId != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Prediction"
                               asp-action="Predict">
                                Predict
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Prediction"
                               asp-action="History">
                                History
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <span class="nav-link text-white">
                                Hello @Context.Session.GetString("UserName")
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-outline-light ms-2"
                               asp-controller="Account"
                               asp-action="Logout">

                                Logout

                            </a>
                        </li>
                    }
                    else if (doctorId != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Doctor"
                               asp-action="Dashboard">

                                Doctor Dashboard

                            </a>
                        </li>

                        <li class="nav-item">
                            <span class="nav-link text-white">
                                Dr. @Context.Session.GetString("DoctorName")
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-outline-light ms-2"
                               asp-controller="DoctorAccount"
                               asp-action="Logout">

                                Logout

                            </a>
                        </li>
                    }
                    else if (admin != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Admin"
                               asp-action="Dashboard">

                                Admin Dashboard

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Admin"
                               asp-action="Users">

                                Users

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Admin"
                               asp-action="Doctors">
                                Doctors
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Admin"
                               asp-action="Predictions">
                                Predictions
                            </a>
                        </li>                    

                        <li class="nav-item">
                            <a class="btn btn-outline-light ms-2"
                               asp-controller="AdminAccount"
                               asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <!-- LOGIN -->

                        <li class="nav-item dropdown">

                            <a class="btn btn-light dropdown-toggle ms-2"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">

                                Login

                            </a>

                            <ul class="dropdown-menu">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Account"
                                       asp-action="Login">

                                        User Login

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="DoctorAccount"
                                       asp-action="Login">

                                        Doctor Login

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="AdminAccount"
                                       asp-action="Login">

                                        Admin Login

                                    </a>
                                </li>

                            </ul>

                        </li>

                        <!-- REGISTER -->

                        <li class="nav-item dropdown">

                            <a class="btn btn-outline-light dropdown-toggle ms-2"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">

                                Register

                            </a>

                            <ul class="dropdown-menu">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Account"
                                       asp-action="Register">

                                        User Register

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="DoctorAccount"
                                       asp-action="Register">

                                        Doctor Register

                                    </a>
                                </li>

                            </ul>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <div class="container-fluid p-0">

        @RenderBody()

    </div>

    <footer class="footer text-center">

        <h5>Heart Disease Prediction System</h5>

        <p>
            MCA Mini Project using ASP.NET Core MVC + Flask API
        </p>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>