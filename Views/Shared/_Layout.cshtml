<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - HeartCare AI</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    <style>
        /* Enhanced Corporate Footer Layout Styling */
        .footer {
            background: #111416; /* Clean deep slate midnight background */
            margin-top: 100px;
            border-top: 4px solid #e63946;
            font-size: 0.95rem;
        }

        .footer-desc {
            color: #94a3b8 !important; /* Premium readable gray-blue text */
            line-height: 1.6;
        }

        .uppercase-title {
            font-size: 0.85rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #f1f5f9 !important;
        }

        .project-tag {
            color: #cbd5e1 !important;
        }

        .footer-links li {
            margin-bottom: 10px;
        }

        .footer-links a {
            color: #94a3b8 !important;
            text-decoration: none;
            transition: all 0.2s ease;
            display: inline-block;
        }

            .footer-links a:hover {
                color: #ffffff !important;
                transform: translateX(4px);
            }

        .footer-links i {
            font-size: 0.75rem;
            color: #e63946;
        }

        .social-icons a {
            transition: color 0.2s ease;
        }

            .social-icons a:hover {
                color: #ffffff !important;
            }
        :root {
            --primary-grad: linear-gradient(135deg, #e63946 0%, #b51724 100%);
            --hero-grad: linear-gradient(135deg, #ff4d5a 0%, #c1121f 100%);
            --dark-bg: #1a1d20;
        }

        body {
            background-color: #f8fafc;
            font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
            color: #334155;
            overflow-x: hidden;
        }

        /* Premium Navbar Styling */
        .navbar {
            background: var(--primary-grad);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 15px 0;
        }

        .navbar-brand, .nav-link {
            color: rgba(255, 255, 255, 0.95) !important;
            font-weight: 600;
            letter-spacing: -0.3px;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: #ffffff !important;
                transform: translateY(-1px);
            }

        /* Footer Customization */
        .footer {
            background: var(--dark-bg);
            color: rgba(255, 255, 255, 0.7);
            padding: 40px 0;
            margin-top: 100px;
            border-top: 4px solid #e63946;
        }

            .footer h5 {
                font-weight: 700;
                color: #ffffff;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 fs-4" asp-controller="Home" asp-action="Index">
                <i class="fas fa-heartbeat text-white"></i>
                <span>HeartCare <span class="fw-light">AI</span></span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var doctorId = Context.Session.GetInt32("DoctorId");
                        var admin = Context.Session.GetString("Admin");
                    }

                    @if (userId != null)
                    {
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Prediction" asp-action="Predict">Predict</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Prediction" asp-action="History">History</a></li>
                        <li class="nav-item"><span class="nav-link text-white fw-semibold px-3">Hello @Context.Session.GetString("UserName")</span></li>
                        <li class="nav-item"><a class="btn btn-outline-light rounded-pill px-4 ms-2 btn-sm" asp-controller="Account" asp-action="Logout">Logout</a></li>
                    }
                    else if (doctorId != null)
                    {
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Doctor" asp-action="Dashboard">Doctor Dashboard</a></li>
                        <li class="nav-item"><span class="nav-link text-white fw-semibold px-3">Dr. @Context.Session.GetString("DoctorName")</span></li>
                        <li class="nav-item"><a class="btn btn-outline-light rounded-pill px-4 ms-2 btn-sm" asp-controller="DoctorAccount" asp-action="Logout">Logout</a></li>
                    }
                    else if (admin != null)
                    {
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Admin" asp-action="Dashboard">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Admin" asp-action="Users">Users</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Admin" asp-action="Doctors">Doctors</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Admin" asp-action="Predictions">Predictions</a></li>
                        <li class="nav-item"><a class="btn btn-outline-light rounded-pill px-4 ms-2 btn-sm" asp-controller="AdminAccount" asp-action="Logout">Logout</a></li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="btn btn-light rounded-pill px-4 btn-sm dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Login</a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Login">User Login</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="DoctorAccount" asp-action="Login">Doctor Login</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="AdminAccount" asp-action="Login">Admin Login</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="btn btn-outline-light rounded-pill px-4 btn-sm dropdown-toggle ms-2" href="#" role="button" data-bs-toggle="dropdown">Register</a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Register">User Register</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="DoctorAccount" asp-action="Register">Doctor Register</a></li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid p-0">
        @RenderBody()
    </div>

    <footer class="footer text-light pt-5 pb-4">
        <div class="container">
            <div class="row g-4">

                <div class="col-lg-5 col-md-6" data-aos="fade-up" data-aos-delay="100">
                    <h5 class="text-white fw-bold mb-3 d-flex align-items-center gap-2">
                        <i class="fas fa-heartbeat text-danger"></i> HeartCare AI
                    </h5>
                    <p class="footer-desc mb-3">
                        An advanced computational diagnostic support system utilizing machine learning models alongside modern web architectures to analyze medical data points smoothly.
                    </p>
                    <p class="project-tag small">
                        <span class="badge bg-danger px-2 py-1 me-1">MCA Project</span>
                        ASP.NET Core 8.0 MVC + Flask REST API
                    </p>
                </div>

                <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                    <h6 class="text-white fw-bold uppercase-title mb-3">System Access</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-controller="Home" asp-action="Index"><i class="fas fa-chevron-right me-2 small"></i>Home Dashboard</a></li>
                        <li><a asp-controller="Prediction" asp-action="Predict"><i class="fas fa-chevron-right me-2 small"></i>Run Diagnostic ML</a></li>
                        <li><a asp-controller="Prediction" asp-action="History"><i class="fas fa-chevron-right me-2 small"></i>Patient Records History</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-12" data-aos="fade-up" data-aos-delay="300">
                    <h6 class="text-white fw-bold uppercase-title mb-3">Model Parameters</h6>
                    <p class="footer-desc small mb-2">
                        System pipeline computes clinical variables including ECG resting metrics, serum cholesterol concentrations, and peak exercise parameters.
                    </p>
                    <div class="d-flex gap-2 mt-3 fs-5 social-icons">
                        <a href="#" class="text-white-50 hover-light"><i class="fab fa-github"></i></a>
                        <a href="#" class="text-white-50 hover-light"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-white-50 hover-light"><i class="fas fa-envelope"></i></a>
                    </div>
                </div>

            </div>

            <hr class="border-secondary my-4 opacity-25" />

            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 small text-white-50">&copy; @DateTime.Now.Year HeartCare AI. All academic research rights reserved.</p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                    <span class="small text-white-50">Designed with precision for healthcare informatics</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({
            once: true,
            duration: 800,
            easing: 'ease-out-cubic'
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>