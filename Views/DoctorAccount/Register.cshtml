@model HeartDiseasePrediction.Models.Doctor

@{
    ViewData["Title"] = "Doctor Registration";
}

<style>
    /* Premium Portal Form Styling */
    .register-container {
        padding-top: 60px;
        padding-bottom: 80px;
    }

    .auth-card {
        border: none;
        border-radius: 24px;
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.02);
        transition: transform 0.3s ease;
    }

    .auth-title {
        font-weight: 700;
        letter-spacing: -1px;
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Modern Input Form Control Overhaul */
    .form-group-custom {
        position: relative;
        margin-bottom: 1.5rem;
    }

        .form-group-custom label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
            margin-bottom: 6px;
            display: block;
        }

    .input-icon-wrapper {
        position: relative;
    }

        .input-icon-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            transition: color 0.3s ease;
        }

    .form-control-custom {
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        padding: 12px 16px 12px 45px;
        font-size: 0.95rem;
        color: #1e293b;
        background-color: #ffffff;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .form-control-custom:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
            outline: none;
        }

            .form-control-custom:focus + i {
                color: #0d6efd;
            }

    /* Submit Button */
    .btn-submit-custom {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white !important;
        font-weight: 600;
        border: none;
        border-radius: 12px;
        padding: 14px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
    }

        .btn-submit-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
            opacity: 0.95;
        }

    .validation-badge {
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="container register-container">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9" data-aos="fade-up" data-aos-duration="800">

            <div class="card auth-card shadow-lg p-4 p-md-5">

                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px; background: #e3f2fd;">
                        <i class="fas fa-user-md fa-lg text-primary"></i>
                    </div>
                    <h2 class="auth-title mb-1">Medical Provider Portal</h2>
                    <p class="text-muted small">Register your clinical credentials to access patient risk data pipelines.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4 p-3 small"></div>
                }

                <form method="post">

                    <div class="form-group-custom">
                        <label>Doctor Name</label>
                        <div class="input-icon-wrapper">
                            <input asp-for="DoctorName" class="form-control form-control-custom w-100" placeholder="Dr. Alex Mercer" />
                            <i class="fas fa-user-md"></i>
                        </div>
                        <span asp-validation-for="DoctorName" class="text-danger validation-badge"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-7">
                            <div class="form-group-custom">
                                <label>Email Address</label>
                                <div class="input-icon-wrapper">
                                    <input asp-for="Email" class="form-control form-control-custom w-100" placeholder="doctor@hospital.com" />
                                    <i class="fas fa-envelope"></i>
                                </div>
                                <span asp-validation-for="Email" class="text-danger validation-badge"></span>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="form-group-custom">
                                <label>Mobile Number</label>
                                <div class="input-icon-wrapper">
                                    <input asp-for="MobileNo" class="form-control form-control-custom w-100" placeholder="Contact number" />
                                    <i class="fas fa-phone"></i>
                                </div>
                                <span asp-validation-for="MobileNo" class="text-danger validation-badge"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <label>Hospital Affiliation</label>
                        <div class="input-icon-wrapper">
                            <input asp-for="HospitalName" class="form-control form-control-custom w-100" placeholder="City General Hospital" />
                            <i class="fas fa-hospital"></i>
                        </div>
                        <span asp-validation-for="HospitalName" class="text-danger validation-badge"></span>
                    </div>

                    <div class="row">
                        <div class="col-sm-8">
                            <div class="form-group-custom">
                                <label>Specialization</label>
                                <div class="input-icon-wrapper">
                                    <input asp-for="Specialization" class="form-control form-control-custom w-100" placeholder="e.g., Cardiology, Internal Medicine" />
                                    <i class="fas fa-stethoscope"></i>
                                </div>
                                <span asp-validation-for="Specialization" class="text-danger validation-badge"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group-custom">
                                <label>Experience (Years)</label>
                                <div class="input-icon-wrapper">
                                    <input asp-for="Experience" class="form-control form-control-custom w-100" placeholder="e.g., 8" />
                                    <i class="fas fa-award"></i>
                                </div>
                                <span asp-validation-for="Experience" class="text-danger validation-badge"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label>Password</label>
                                <div class="input-icon-wrapper">
                                    <input asp-for="Password" type="password" class="form-control form-control-custom w-100" placeholder="••••••••" />
                                    <i class="fas fa-lock"></i>
                                </div>
                                <span asp-validation-for="Password" class="text-danger validation-badge"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group-custom">
                                <label>Confirm Password</label>
                                <div class="input-icon-wrapper">
                                    <input type="password" name="ConfirmPassword" class="form-control form-control-custom w-100" placeholder="••••••••" />
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-submit-custom w-100 mt-2 py-3 fs-6">
                        Register Clinical Account <i class="fas fa-chevron-right ms-2 small"></i>
                    </button>

                </form>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-danger rounded-3 mt-4 text-center small mb-0">
                        <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Message
                    </div>
                }

            </div>

        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}